CheckOldTool = falseMessureNewTool = trueCheckForPlausibleToolHight = trueProbePos = 84ToolHightPlausibleDiff = 0.2CurrentFeed = GetOemDRO(818) 'Get the current feedrate to return to laterCurrentAbsInc = GetOemLED(48) 'Get the current G90/G91 stateCurrentGmode = GetOemDRO(819) 'Get the current G0/G1 stateCurrentFeedOverride = GetOEMDRO(821)'Get current Feedrate override settingDoOEMButton(180)OldTool = GetOemDRO(824) 'Tool In spindle DRO You must add this to your settings screenNewTool = GetSelectedTool()'Tool inside the M6 CommandMaxToolNum = 11 'Max number of tools for the changerIf NewTool > 99 Then	If NewTool = 100 Then		End	End If	DoSpinStop()	Code "G90"	Code "G53 G01 F9000 Z0"  'First clear Z to max hight	While IsMoving()	sleep(10)	Wend	NewTool = NewTool - 100	Call MoveToToolSlot(NewTool) 'Move above tool slot	EndEnd IfMessage "Tool Change Started: Current Tool: " & OldTool & " New Tool: " & NewToolIf NewTool = OldTool Then 'Same tool abort	Code "(Tool Change Warning: SAME TOOL)"	EndEnd IfIf NewTool > MaxToolNum Then 'Tool dosnt exist	Code "(Tool Change Error: NEW TOOL DOENST EXIST)"	DoOEMButton(1003)	EndEnd IfIf OldTool > MaxToolNum Then 'Old Tool dosnt exist	Code "(Tool Change Error: OLD TOOL DOENST EXIST)"	DoOEMButton(1003)	EndEnd IfDoSpinStop()Code "G90"Code "G53 G01 F6000 Z0"  'First clear Z to max hight'DoButton(24)'DoButton(22)'DoButton(23) While IsMoving()sleep(10)WendIf OldTool > 0 Then	If CheckOldTool Then		Call MeassureTool()	End If	Code "G53 G01 F9000 X0"  'First clear Z to max hight	While IsMoving()	sleep(10)	Wend	Code "G53 G01 F9000 Y42"  'First clear Z to max hight	While IsMoving()	sleep(10)	Wend	Call MoveToToolSlot(OldTool) 'Move above tool slot	While IsMoving()	sleep(10)	Wend	Code "G53 G01 F9000 Z-79"'Move Z into tool slot	While IsMoving()	sleep(10)	Wend	SetSpinSpeed(900)	DoSpinCCW()	sleep(1200)	Code "G53 G01 F9000 Z-68" 'Move Z to max hight	While IsMoving()	sleep(10)	Wend	DoSpinStop()	Code "G53 G01 F9000 Z0" 'Move Z to max hight	While IsMoving()	sleep(10)	Wend	'If GetOEMLED(822) = 0 Then		'Message "Error: Old Tool STUCK in Spindle"		'sleep(3000)		'DoOEMButton(1003)		'Call EndThisProgram()	'End If	SetCurrentTool( 0 )End IfIf NewTool > 0 Then	Call MoveToToolSlot(NewTool) 'Move above tool slot	While IsMoving()	sleep(10)	Wend	Code "G53 G01 F9000 Z-79"'Move Z into tool slot	While IsMoving()	sleep(10)	Wend	SetSpinSpeed(600)	DoSpinCW() 	sleep(1700)	Code "G53 G01 F9000 Z0" 'Move Z to max hight	DoSpinStop()	While IsMoving()	sleep(10)	Wend		'If GetOEMLED(822) Then'Message "Error: New Tool STUCK in Tool Holder"		'sleep(3000)		'DoOEMButton(1003)		'Call EndThisProgram()	'End If			Call SetUserDRO (1200,NewTool)	SetCurrentTool( NewTool )	Code "G53 G01 F9000 Y42"	While IsMoving()	sleep(10)	Wend	Code "G53 G01 F9000 X25"	While IsMoving()	sleep(10)	Wend	If MessureNewTool Then		Call MeassureTool()	End If	Code "G43"End IfCall EndThisProgram()'END OF TOOL CHANGEEndSub MeassureTool()ToolHightFromToolTable = GetToolParam(GetOemDRO(824),2)SetToolParam(0,2,0)SetToolParam(GetOemDRO(824),2,0)Code "G43 H" & GetOemDRO(824)Message "Tool Hight Started: Current Tool: " & GetOemDRO(824)DownStroke = 1000SmallRetractStroke = 0.5 'Retract 1mm for a 2nd passSmallDownStroke = -(SmallRetractStroke *2) 'Set down stroke for 2nd pass as twice the retract distance.Code "G90 G53 G01 F9000 Z0"  'First clear Z to max hightCode "G53 G01 X24.5667 Y67.8799" 'Tool Probe OWhile IsMoving()sleep(10)WendStartZOffset = GetOEMDRO(180)If GetOemLed (825)=0 Then 'Check to see if the probe is already grounded or faulty	Code "G31 Z" & -(DownStroke) & " F1500" 'Probe Down in Work Coordinates (G53 doesnt work with G31)	While IsMoving() 'wait while it happens	sleep (10)	Wend	sleep(100)	'ZProbePos = GetOEMDRO(85) 'get Z axis position	ZProbePos = GetVar(2002)' G31 Value recoded	If Abs(ZprobePos) <= Abs(DownStroke)-1 Then 'Check if the probe has been found		Code "G91 G1 Z" & SmallRetractStroke & " F500" 'Retract		While IsMoving ()		sleep(10)		Wend		If GetOemLed (825)<>0 Then 'Check to see if the probe is grounded			Code "(Tool Probe Error: Retract to small !)" 'this goes in the status bar if aplicable			Code "G90 G53 G01 F9000 Z0"  'First clear Z to max hight			While IsMoving ()			sleep(10)			Wend			DoOEMButton(1003)			Call EndThisProgram()		End If	Else		Code "G90 G53 G01 F9000 Z0"		While IsMoving ()		sleep(10)		Wend		Code "(Tool Probe Error: 1st Run Probe was not hit)" 'puts this message in the status bar		DoOEMButton(1003)		Call EndThisProgram()	End IfElse	Code "(Tool Probe Error: Z-Plate is grounded)" 'this goes in the status bar if aplicable	DoOEMButton(1003)	Call EndThisProgram()End IfZProbePosStart = GetOEMDRO(85) 'get Z axis positionCode "G91 G31 Z" & SmallDownStroke &" F20"While IsMoving() 'wait while it happenssleep(10)Wendsleep(200)'ZProbePos = GetOEMDRO(85) 'get Z axis positionZProbePos = (GetVar(2002) - StartZOffset) + ProbePos' G31 Value recoded	Code "G90 G53 G01 F9000 Z0"  'First clear Z to max hight	Message "Tool Probe Completed! Tool height=" & ZProbePos	sleep(1)	Diff = ZProbePos - ToolHightFromToolTable	If ToolHightFromToolTable <> 0 And CheckForPlausibleToolHight Then		If Abs(Diff) > ToolHightPlausibleDiff Then			Message "Error Diff To Greate: Tool Hight: " & ZProbePos & " Found In Tool Table: " & ToolHightFromToolTable & " Diff: " & Diff			SetToolParam(GetOemDRO(824),2,ZProbePos)			DoOEMButton(316)			While IsMoving ()			sleep(10)			Wend 			Code "F" &CurrentFeed 'Returns to prior feed rate			SetOEMDRO(821,CurrentFeedOverride) 'Return feedrate override to previous value			If CurrentAbsInc = 0 Then 'if G91 was in effect before then return to it				Code "G91"			End If			If CurrentGMode = 0 Then 'if G0 was in effect before then return to it				Code "G0"			End If			DoOEMButton(180)			DoOEMButton(1001)			End		End If	End If	Message "Tool Hight: " & ZProbePos & " Found In Tool Table: " & ToolHightFromToolTable & " Diff: " & Diff	SetToolParam(GetOemDRO(824),2,ZProbePos)	DoOEMButton(316)	Code "G43 H" & GetOemDRO(824)	While IsMoving ()	sleep(10)	Wend End SubSub MoveToToolSlot(ByVal ToolNumber As Integer) 'Function	Select Case ToolNumber	Case Is = 1	Xpos = 1.9545	YPos = 2.8059	Case Is = 2	Xpos = 65.16	YPos = 2.495	Case Is = 3	Xpos = 128.209	YPos = 1.232	Case Is = 4	Xpos = 191.92	YPos = 2.083	Case Is = 5	Xpos = 254.162	YPos = 1.7	Case Is = 6	Xpos = 316.88	YPos = 2.208	Case Is = 7	Xpos = 378.495	YPos = 2.208	Case Is = 8	Xpos = 380.022	YPos = 81.573	Case Is = 9	Xpos = 317.669	YPos = 81.984	Case Is = 10	Xpos = 255.225	YPos = 81.582	Case Is = 11	Xpos = 192.335	YPos = 82.840	End Select	If GetOemDRO(824) <> 0 Then		Code "G53 G01 F9000 X" & XPos		While IsMoving()		sleep(10)		Wend		Code "G53 G01 F9000 X" & XPos & " Y" & YPos	Else		Code "G53 G01 F9000 X" & XPos & " Y" & YPos	End If	While IsMoving()	sleep(10)	WendEnd Sub                     Sub EndThisProgram ()	Code "F" &CurrentFeed 'Returns to prior feed rate	SetOEMDRO(821,CurrentFeedOverride) 'Return feedrate override to previous value	If CurrentAbsInc = 0 Then 'if G91 was in effect before then return to it		Code "G91"	End If	If CurrentGMode = 0 Then 'if G0 was in effect before then return to it		Code "G0"	End If	DoOEMButton(180)	EndEnd Sub                                                         